---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThroughlineIcon from '../components/ThroughlineIcon.astro';
import { getCollection } from 'astro:content';

const allChangelog = await getCollection('changelog');
const latestChangelog = allChangelog
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allWriting = await getCollection('writing', ({ data }) => data.published);
const latestWriting = allWriting
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toISOString().slice(0, 10);
}
---

<BaseLayout>
  <div class="intro">
    <ThroughlineIcon />
    <p>
      Product marketer and builder with a love for brand strategy, creative production, and figuring out why things matter and how to make people feel it.
    </p>
    <p>
      Currently leading Product Marketing at <a href="https://www.whoop.com/us/en/" target="_blank" rel="noopener">WHOOP</a>. Lately building with AI in ways that changed how I think about work.
    </p>
  </div>

  {latestChangelog.length > 0 && (
    <section>
      <div class="section-header">
        <h2>Changelog</h2>
        <a href="/changelog">View all &rarr;</a>
      </div>
      {latestChangelog.map(async (entry) => {
        const { Content } = await entry.render();
        return (
          <div class="changelog-entry">
            <div class="changelog-date">{formatDate(entry.data.date)}</div>
            <div class="changelog-body"><Content /></div>
          </div>
        );
      })}
    </section>
  )}

  {latestWriting.length > 0 && (
    <section style="margin-top: var(--space-2xl);">
      <div class="section-header">
        <h2>Writing</h2>
        <a href="/writing">View all &rarr;</a>
      </div>
      {latestWriting.map((post) => (
        <div class="writing-entry">
          <div class="writing-title">
            <a href={post.data.url || `/writing/${post.id}`}>{post.data.title}</a>
          </div>
          <div class="writing-meta">{formatDate(post.data.date)}</div>
          {post.data.description && <p class="writing-description">{post.data.description}</p>}
        </div>
      ))}
    </section>
  )}

  <section class="say-yo">
    <h2>Say Yo</h2>
    <ul>
      <li>X: <a href="https://x.com/yo_friedman/" target="_blank" rel="noopener">@yo_friedman</a></li>
      <li>LinkedIn: <a href="https://www.linkedin.com/in/yofriedman/" target="_blank" rel="noopener">yofriedman</a></li>
      <li>GitHub: <a href="https://github.com/yofriedman" target="_blank" rel="noopener">yofriedman</a></li>
    </ul>
  </section>
</BaseLayout>
