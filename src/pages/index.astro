---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThroughlineIcon from '../components/ThroughlineIcon.astro';
import { getCollection } from 'astro:content';

const allChangelog = await getCollection('changelog');
const latestChangelog = allChangelog
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const allWriting = await getCollection('writing', ({ data }) => data.published);
const latestWriting = allWriting
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toISOString().slice(0, 10);
}

function formatDateDisplay(date: Date) {
  const months = ['January','February','March','April','May','June',
                  'July','August','September','October','November','December'];
  const d = date.getUTCDate();
  const suffix = d === 1 || d === 21 || d === 31 ? 'st'
               : d === 2 || d === 22 ? 'nd'
               : d === 3 || d === 23 ? 'rd'
               : 'th';
  return `${months[date.getUTCMonth()]} ${d}${suffix}, ${date.getUTCFullYear()}`;
}
---

<BaseLayout>
  <div class="intro">
    <ThroughlineIcon />
    <p>
      I've spent fifteen years figuring out how to close the distance between an idea and the person it's meant for.
    </p>
    <p>
      Leading product marketing at <a href="https://www.whoop.com/us/en/" target="_blank" rel="noopener">WHOOP</a> and building with AI in ways that changed what I think knowledge work can be.
    </p>
  </div>

  {latestWriting.length > 0 && (
    <section>
      <div class="section-header">
        <h2>Writing</h2>
        <a href="/writing">View all &rarr;</a>
      </div>
      {latestWriting.map((post) => (
        <div class="writing-entry">
          <div class="writing-title">
            <a href={post.data.url || `/writing/${post.id}`}>{post.data.title}</a>
          </div>
          <div class="writing-meta">{formatDate(post.data.date)}</div>
          {post.data.description && <p class="writing-description">{post.data.description}</p>}
        </div>
      ))}
    </section>
  )}

  {latestChangelog.length > 0 && (
    <section style="margin-top: var(--space-2xl);">
      <div class="section-header">
        <h2>Changelog</h2>
        <a href="/changelog">View all &rarr;</a>
      </div>
      <div class="cl-timeline">
        {latestChangelog.map(async (entry, i) => {
          const { Content } = await entry.render();
          const isContinuation = i > 0 && formatDate(entry.data.date) === formatDate(latestChangelog[i - 1].data.date);
          const isFollowedByContinuation = i < latestChangelog.length - 1 && formatDate(entry.data.date) === formatDate(latestChangelog[i + 1].data.date);
          const showLine = i < latestChangelog.length - 1 || isContinuation;
          return (
            <div class:list={['cl-entry', { 'cl-entry--group-continues': isFollowedByContinuation }]}>
              <div class:list={['cl-track', { 'cl-track--continuation': isContinuation }]}>
                {!isContinuation && <div class:list={['cl-dot', { 'cl-dot--latest': i === 0 }]} />}
                {showLine && <div class="cl-line" />}
              </div>
              <div class:list={['cl-content', { 'cl-content--continuation': isContinuation }]}>
                {!isContinuation && <div class="cl-date">{formatDateDisplay(entry.data.date)}</div>}
                <div class="cl-body"><Content /></div>
              </div>
            </div>
          );
        })}
      </div>
    </section>
  )}

  <section class="say-yo">
    <h2>Say Yo</h2>
    <ul>
      <li>X: <a href="https://x.com/yo_friedman/" target="_blank" rel="noopener">@yo_friedman</a></li>
      <li>LinkedIn: <a href="https://www.linkedin.com/in/yofriedman/" target="_blank" rel="noopener">yofriedman</a></li>
      <li>GitHub: <a href="https://github.com/yofriedman" target="_blank" rel="noopener">yofriedman</a></li>
    </ul>
  </section>
</BaseLayout>
