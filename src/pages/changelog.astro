---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allChangelog = await getCollection('changelog');
const entries = allChangelog.sort((a, b) => {
  const dateDiff = b.data.date.getTime() - a.data.date.getTime();
  if (dateDiff !== 0) return dateDiff;
  return (b.data.order ?? 0) - (a.data.order ?? 0);
});

function formatDate(date: Date) {
  return date.toISOString().slice(0, 10);
}

function formatDateDisplay(date: Date) {
  const months = ['January','February','March','April','May','June',
                  'July','August','September','October','November','December'];
  const d = date.getUTCDate();
  const suffix = d === 1 || d === 21 || d === 31 ? 'st'
               : d === 2 || d === 22 ? 'nd'
               : d === 3 || d === 23 ? 'rd'
               : 'th';
  return `${months[date.getUTCMonth()]} ${d}${suffix}, ${date.getUTCFullYear()}`;
}
---

<BaseLayout title="Changelog">
  <div class="page-header">
    <h1>Changelog</h1>
    <p>A running log of what I'm building, thinking, shipping, and learning.</p>
  </div>

  <div class="cl-timeline">
    {entries.map(async (entry, i) => {
      const { Content } = await entry.render();
      const isContinuation = i > 0 && formatDate(entry.data.date) === formatDate(entries[i - 1].data.date);
      const isFollowedByContinuation = i < entries.length - 1 && formatDate(entry.data.date) === formatDate(entries[i + 1].data.date);
      const showLine = i < entries.length - 1 || isContinuation;
      return (
        <div class:list={['cl-entry', { 'cl-entry--group-continues': isFollowedByContinuation }]}>
          <div class:list={['cl-track', { 'cl-track--continuation': isContinuation }]}>
            {!isContinuation && <div class:list={['cl-dot', { 'cl-dot--latest': i === 0 }]} />}
            {showLine && <div class="cl-line" />}
          </div>
          <div class:list={['cl-content', { 'cl-content--continuation': isContinuation }]}>
            {!isContinuation && <div class="cl-date">{formatDateDisplay(entry.data.date)}</div>}
            <div class="cl-body"><Content /></div>
          </div>
        </div>
      );
    })}
  </div>
</BaseLayout>
