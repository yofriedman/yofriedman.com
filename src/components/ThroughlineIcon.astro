---
// Throughline icon — dot pulses, splits, grows through shapes:
// dot → line → triangle → diamond → octahedron. Rotates in 3D.
---

<div class="throughline-icon" aria-hidden="true">
  <svg class="tl-svg" viewBox="0 0 100 100" width="64" height="64"></svg>
</div>

<style is:global>
  .throughline-icon {
    margin-bottom: var(--space-md);
    margin-left: -13px;
  }
  .tl-svg circle {
    fill: var(--accent);
  }
  .tl-svg line {
    stroke: var(--text);
    stroke-width: 1.2;
  }
</style>

<script>
  (function () {
    const svg = document.querySelector('.tl-svg');
    if (!svg) return;
    const NS = 'http://www.w3.org/2000/svg';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Octahedron — 6 vertices, perfectly symmetric.
    // Build order: top, bottom (line), right (triangle), left (diamond), front (3D), back (complete)
    const pos = [
      [0, -1, 0],    // 0: top
      [0, 1, 0],     // 1: bottom  → line
      [1, 0, 0],     // 2: right   → triangle
      [-1, 0, 0],    // 3: left    → diamond
      [0, 0, 1],     // 4: front   → 3D begins
      [0, 0, -1],    // 5: back    → octahedron complete
    ];
    const N = pos.length;

    // Fully connected (15 edges)
    const edges: [number, number][] = [];
    for (let i = 0; i < N; i++)
      for (let j = i + 1; j < N; j++)
        edges.push([i, j]);

    // Timing
    const PULSE = 1.5;   // intro pulse duration
    const GAP = 0.55;
    const SLIDE = 0.6;

    function slideStart(i: number) {
      if (i === 0) return PULSE;
      return PULSE + (i - 1) * GAP;
    }
    function birthTime(i: number) {
      return i === 0 ? 0 : slideStart(i);
    }

    // Cycle phases
    const BUILD_END    = slideStart(N - 1) + SLIDE; // ~3.9s — all vertices fully out
    const ACCEL_DUR    = 10.0;  // 10s ramp: 1x → 3x
    const PAUSE_DUR    = 0.4;   // abrupt stop — shape holds before collapsing
    const COLLAPSE_DUR = 0.5;   // quick collapse back to dot
    const DOT_DUR      = 0.3;   // single dot fades out

    const ACCEL_END    = BUILD_END + ACCEL_DUR;
    const PAUSE_END    = ACCEL_END + PAUSE_DUR;
    const COLLAPSE_END = PAUSE_END + COLLAPSE_DUR;
    const CYCLE        = COLLAPSE_END + DOT_DUR;     // ~31s total

    const SPEED = (2 * Math.PI) / 15; // base rotation speed — one full turn every 15s

    // Create SVG elements
    const lineEls = edges.map(() => {
      const el = document.createElementNS(NS, 'line');
      el.setAttribute('opacity', '0');
      svg.appendChild(el);
      return el;
    });
    const circleEls = pos.map(() => {
      const el = document.createElementNS(NS, 'circle');
      el.setAttribute('r', '4.7');
      el.setAttribute('opacity', '0');
      svg.appendChild(el);
      return el;
    });

    // 3D projection — CX offset left to align with text margin
    const RAD = 32, CX = 36, CY = 50;
    const TILT_AMOUNT = 0.35;                      // axis tilt from vertical (radians)
    const DRIFT_SPEED = (2 * Math.PI) / 90;        // full precession every 90s

    function easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }
    function easeIn(t: number)  { return t * t * t; }
    function depth(z: number)   { return 0.4 + 0.6 * (z + 1) / 2; }

    function project(p: number[], a: number, drift: number) {
      // Rotation axis: tilted TILT_AMOUNT from vertical, azimuth slowly drifts
      const ax = Math.sin(TILT_AMOUNT) * Math.cos(drift);
      const ay = Math.cos(TILT_AMOUNT);
      const az = Math.sin(TILT_AMOUNT) * Math.sin(drift);
      // Rodrigues' rotation of p around axis [ax,ay,az] by angle a
      const cosA = Math.cos(a), sinA = Math.sin(a);
      const dot   = p[0]*ax + p[1]*ay + p[2]*az;
      const cx = ay*p[2] - az*p[1];
      const cy = az*p[0] - ax*p[2];
      const cz = ax*p[1] - ay*p[0];
      const rx = p[0]*cosA + cx*sinA + ax*dot*(1-cosA);
      const ry = p[1]*cosA + cy*sinA + ay*dot*(1-cosA);
      const rz = p[2]*cosA + cz*sinA + az*dot*(1-cosA);
      return [CX + rx * RAD, CY + ry * RAD, rz];
    }

    // Vertex position within a cycle — builds out, holds while accelerating, then collapses
    function vertexPos(i: number, t: number): number[] {
      const ss      = slideStart(i);
      const elapsed = t - ss;
      if (elapsed <= 0) return [0, 0, 0];
      const builtScale = easeOut(Math.min(1, elapsed / SLIDE));
      if (t < PAUSE_END) {
        return [pos[i][0] * builtScale, pos[i][1] * builtScale, pos[i][2] * builtScale];
      }
      if (t < COLLAPSE_END) {
        const cp    = (t - PAUSE_END) / COLLAPSE_DUR;
        const scale = 1 - easeIn(cp);
        return [pos[i][0] * scale, pos[i][1] * scale, pos[i][2] * scale];
      }
      return [0, 0, 0];
    }

    let startTime:  number | null = null;
    let angle      = 0;
    let driftAngle = 0;
    let lastRawT   = 0;

    function frame(ts: number) {
      if (!startTime) startTime = ts;
      const rawT = (ts - startTime) / 1000;
      const dt   = Math.min(rawT - lastRawT, 0.05);
      lastRawT   = rawT;

      const t = rawT % CYCLE;

      // Speed: linearly 1x → 2x over 25s, stopped during pause/collapse/dot
      let speed = SPEED;
      if (t >= BUILD_END && t < ACCEL_END) {
        const elapsed = t - BUILD_END;             // 0 → 25s
        const pct     = elapsed / ACCEL_DUR;       // 0 → 1
        speed = SPEED * (1 + easeOut(pct) * 2);     // 1x → 3x, logarithmic curve
      } else if (t >= ACCEL_END) {
        speed = 0; // stopped: pause, collapse, dot
      }
      angle      += speed * dt;
      driftAngle += DRIFT_SPEED * dt;

      const vpos = pos.map((_, i) => vertexPos(i, t));
      const proj = vpos.map(vp => project(vp, angle, driftAngle));

      circleEls.forEach((el, i) => {
        // Initial big pulse for vertex 0 (plays each cycle restart)
        if (i === 0 && t < PULSE) {
          const p = t / PULSE;
          const o = Math.min(1, p * 4);
          let r: number;
          if (p < 0.08)      r = 12 * (p / 0.08);              // 0 → 12: pop in big
          else if (p < 0.22) r = 12 + 4 * ((p - 0.08) / 0.14); // 12 → 16: pulse up
          else if (p < 0.40) r = 16 - 6 * ((p - 0.22) / 0.18); // 16 → 10: pulse back
          else                r = 10 - 5.3 * ((p - 0.40) / 0.60); // 10 → 4.7: settle
          el.setAttribute('cx', proj[0][0].toFixed(1));
          el.setAttribute('cy', proj[0][1].toFixed(1));
          el.setAttribute('r', r.toFixed(2));
          el.setAttribute('opacity', o.toFixed(2));
          return;
        }

        const bt  = birthTime(i);
        const age = t - bt;
        if (age < 0) { el.setAttribute('opacity', '0'); return; }

        // DOT phase: hide all but vertex 0
        if (t >= COLLAPSE_END && i !== 0) { el.setAttribute('opacity', '0'); return; }

        const [px, py, z] = proj[i];
        const d = depth(z);
        let r = 4.7, o = 1;

        // Fade-in pop for newly born vertices
        if (i > 0 && age < 0.15) {
          const p = age / 0.15;
          r = 4.7 * p;
          o = p;
        }

        // Collapse: fade out non-0 vertices as they converge to center
        if (t >= PAUSE_END && i !== 0) {
          const cp = (t - PAUSE_END) / COLLAPSE_DUR;
          o *= (1 - easeIn(Math.min(1, cp)));
        }

        // DOT phase: vertex 0 fades out before cycle reset
        if (t >= COLLAPSE_END && i === 0) {
          const dp = (t - COLLAPSE_END) / DOT_DUR;
          o *= (1 - dp);
        }

        el.setAttribute('cx', px.toFixed(1));
        el.setAttribute('cy', py.toFixed(1));
        el.setAttribute('r', (r * d).toFixed(2));
        el.setAttribute('opacity', (o * d).toFixed(2));
      });

      edges.forEach(([i, j], idx) => {
        if (t >= COLLAPSE_END) { lineEls[idx].setAttribute('opacity', '0'); return; }

        const iAge = t - birthTime(i);
        const jAge = t - birthTime(j);
        if (iAge < 0 || jAge < 0) { lineEls[idx].setAttribute('opacity', '0'); return; }

        const laterAge = Math.min(iAge, jAge);
        const fadeIn   = Math.min(1, laterAge / 0.3);
        const [x1, y1, z1] = proj[i];
        const [x2, y2, z2] = proj[j];
        const avgD = depth((z1 + z2) / 2);
        let lineO  = 0.25 * avgD * fadeIn;

        // Fade edges during collapse
        if (t >= PAUSE_END) {
          const cp = (t - PAUSE_END) / COLLAPSE_DUR;
          lineO *= (1 - easeIn(cp));
        }

        lineEls[idx].setAttribute('x1', x1.toFixed(1));
        lineEls[idx].setAttribute('y1', y1.toFixed(1));
        lineEls[idx].setAttribute('x2', x2.toFixed(1));
        lineEls[idx].setAttribute('y2', y2.toFixed(1));
        lineEls[idx].setAttribute('opacity', lineO.toFixed(2));
      });

      requestAnimationFrame(frame);
    }

    if (reduced) {
      // Static: full octahedron at rest
      const proj = pos.map(p => project(p, 0, 0));
      circleEls.forEach((el, i) => {
        const [px, py, z] = proj[i];
        const d = depth(z);
        el.setAttribute('cx', px.toFixed(1));
        el.setAttribute('cy', py.toFixed(1));
        el.setAttribute('r', (4.7 * d).toFixed(2));
        el.setAttribute('opacity', d.toFixed(2));
      });
      edges.forEach(([i, j], idx) => {
        const [x1, y1, z1] = proj[i];
        const [x2, y2, z2] = proj[j];
        lineEls[idx].setAttribute('x1', x1.toFixed(1));
        lineEls[idx].setAttribute('y1', y1.toFixed(1));
        lineEls[idx].setAttribute('x2', x2.toFixed(1));
        lineEls[idx].setAttribute('y2', y2.toFixed(1));
        lineEls[idx].setAttribute('opacity', (0.25 * depth((z1 + z2) / 2)).toFixed(2));
      });
    } else {
      requestAnimationFrame(frame);
    }
  })();
</script>
